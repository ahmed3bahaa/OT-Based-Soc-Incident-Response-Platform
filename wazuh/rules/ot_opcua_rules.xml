<group name="ot,opcua,">

  <!-- Base classification only. Normal successful writes do not alert. -->
  <rule id="110100" level="0">
    <decoded_as>json</decoded_as>
    <field name="event.action">^opcua_write$</field>
    <description>OT OPC UA write operation observed.</description>
    <group>ot,opcua,write,</group>
  </rule>

  <!-- A write operation explicitly reported as failed. -->
  <rule id="110101" level="7">
    <if_sid>110100</if_sid>
    <field name="event.outcome">^failure$</field>
    <description>OT OPC UA write failed.</description>
    <group>ot,opcua,write_failure,</group>
  </rule>

  <!-- The client wrote a value but read back a different value. -->
  <rule id="110102" level="10">
    <if_sid>110101</if_sid>
    <field name="ot.verified">^false$</field>
    <description>OT OPC UA write verification mismatch.</description>
    <group>ot,opcua,verification_mismatch,</group>
  </rule> 

  <rule id="110103" level="3">
    <decoded_as>json</decoded_as>
    <field name="event.action">^opcua_datachange$</field>
    <field name="event.outcome">^observed$</field>
    <field name="ot.protocol">^opcua$</field>
    <field name="ot.operation">^datachange$</field>
    <field name="ot.change_origin">^unknown_from_subscription$</field>
    <description>OT OPC UA datachange observed by passive monitor - validation scenario</description>
    <group>ot,opcua,monitor,datachange,validation,</group>
  </rule>
<rule id="110104" level="3">
  <if_sid>86600</if_sid>
  <field name="event_type">^flow$</field>
  <field name="proto">^TCP$</field>
  <field name="dest_ip">^192\.168\.56\.1$</field>
  <field name="dest_port">^49320$</field>
  <description>OT OPC UA network flow observed by Suricata - validation scenario</description>
  <group>ot,opcua,suricata,network,validation,</group>
</rule>
<rule id="110105" level="3">
  <decoded_as>json</decoded_as>
  <field name="event.action">^kepserver_opcua_write$</field>
  <field name="event.outcome">^success$</field>
  <field name="ot.protocol">^opcua$</field>
  <field name="ot.operation">^write$</field>
  <field name="ot.evidence_source">^kepserver_opc_diagnostics$</field>
  <description>OT OPC UA write observed in KEPServerEX diagnostics - validation scenario</description>
  <group>ot,opcua,kepserver,diagnostics,validation,</group>
</rule>
</group>
