# Copy this file to .env in the repository root.
# Never commit .env; it is intentionally ignored by Git and Docker builds.

# PostgreSQL 18 local Docker database
POSTGRES_DB=ot_soc
POSTGRES_USER=ot_soc
POSTGRES_PASSWORD=
POSTGRES_HOST_PORT=5434

# Django backend
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=backend,localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Set only for local validation commands when you want Django to ignore this file.
OT_SOC_SKIP_DOTENV=

# Frontend to backend routing
OT_SOC_API_BASE_URL=http://backend:8000/api
NEXT_PUBLIC_OT_SOC_API_BASE_URL=http://127.0.0.1:8000/api

# Wazuh Indexer/OpenSearch polling.
# Port 9200 uses Wazuh indexer credentials, not Wazuh server API port 55000.
WAZUH_INDEXER_ALERTS_URL=https://<WAZUH_INDEXER_IP>:9200/wazuh-alerts-*/_search
WAZUH_ALERTS_URL=
WAZUH_API_USERNAME=
WAZUH_API_PASSWORD=
WAZUH_API_TOKEN=
WAZUH_API_INSECURE=true
WAZUH_ALERTS_METHOD=POST
WAZUH_ALERTS_SIZE=100
WAZUH_ALERTS_POLL_INTERVAL=5
WAZUH_ALERTS_LOOKBACK_SECONDS=1800
OT_SOC_CORRELATION_WINDOW_SECONDS=900
